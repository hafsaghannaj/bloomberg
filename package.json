{
  "name": "bloomberg-terminal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "ios:build": "cp next.config.ts next.config.backup.ts && cp next.config.ios.ts next.config.ts && next build && cp next.config.backup.ts next.config.ts && rm next.config.backup.ts && npx cap sync ios",
    "ios:sync": "npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:dev": "npx cap run ios --livereload --external"
  },
  "dependencies": {
    "@capacitor-community/http": "^1.4.1",
    "@capacitor/core": "^8.0.2",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@tanstack/react-query": "^5.90.20",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jspdf": "^4.1.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "numeral": "^2.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-grid-layout": "^2.2.2",
    "recharts": "^3.7.0",
    "yahoo-finance2": "^3.13.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/numeral": "^2.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-grid-layout": "^1.3.6",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
